"""
tomar los metodosque esten en el pdf y ususarios para hacer un crud, deben hacer una base de datos extructurada con array deben tener la informacion del cliente (solo el nombre )


en el codigo principal debe haber un menu de trabajo como interfaz de usuario con las 9 opciones que tien el pdf

1.guardar un cliente
2.guardar varios clientes
3.insertar cliente en posicion determinada
4. eliminar cliente
5.buscar cliente y eliminar cliente
6.buscar cliente e imprimir cliente
7. buscar cliente
8.contar las veces que se repite el cliente
9.ordenar lista menor a mayor
10.ordenar lista mayor a menor
11. ver base de datos
12.salir del sistema
"""

class Lista_cliente:
    def __init__(self):
        self.base_datos = []

    def guardar_cliente(self, nombre):
        self.base_datos.append([nombre])

    def guardar_varios(self, nombres):
        self.base_datos.extend(nombres)

    def insertar_posicion(self, nombre, pos):
        self.base_datos.insert(pos, [nombre])

    def eliminar_posicion(self, pos):
        self.base_datos.pop(pos)

    def buscar_eliminar(self, nombre):
        posicion = self.base_datos.index([nombre])
        self.base_datos.pop(posicion)

    def buscar_imprimir(self, nombre):
        posicion = self.base_datos.index([nombre])
        print(f"cliente {self.base_datos[posicion]} en posicion {posicion}")

    def buscar_cliente(self, nombre):
        posicion = self.base_datos.index([nombre])
        print(f"El cliente está en la posición {posicion}")

    def contar_cliente(self, nombre):
        total = self.base_datos.count([nombre])
        print(f"se repite {total} de veces")

    def ordenar_menor_mayor(self):
        self.base_datos.sort()

    def ordenar_mayor_menor(self):
        self.base_datos.sort()
        self.base_datos.reverse()

    def ver_datos(self):
        for i in range(len(self.base_datos)):
            print(f"informacion de bases de datos: {self.base_datos[i]}")

# zona codigo principal:
obj_db = Lista_cliente()
