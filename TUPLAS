class Triangulo:
  def __init__(self):
        self.lado = 0
        self.altura = 0
        self.area = 0

  def tomar_lado(self):
        self.lado = int(input("digite el lado del triangulo: "))

  def tomar_altura(self):
        self.altura = int(input("digite la altura del triangulo: "))

  def hallar_area(self):
        self.area = (self.lado * self.altura) / 2

